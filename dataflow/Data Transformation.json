{
	"name": "Data Transformation",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dataflowSource",
						"type": "DatasetReference"
					},
					"name": "sourceCSV"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "dataflow_sink",
						"type": "DatasetReference"
					},
					"name": "sinkDataflow"
				}
			],
			"transformations": [
				{
					"name": "selectData"
				},
				{
					"name": "filterRows"
				},
				{
					"name": "splitPayment"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "aggregate"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          transaction_id as short,",
				"          transactional_date as timestamp,",
				"          product_id as string,",
				"          customer_id as short,",
				"          payment as string,",
				"          credit_card as long,",
				"          loyalty_card as boolean,",
				"          cost as double,",
				"          quantity as short,",
				"          price as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceCSV",
				"sourceCSV select(mapColumn(",
				"          transaction_id,",
				"          transactional_date,",
				"          product_id,",
				"          customer_id,",
				"          payment,",
				"          price",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectData",
				"selectData filter(customer_id != 12) ~> filterRows",
				"filterRows split(payment == 'visa',",
				"     payment == 'americanexpress',",
				"     disjoint: false) ~> splitPayment@(visa, amex, mastercard)",
				"splitPayment@mastercard derive(payment = coalesce(payment, 'N/A')) ~> derivedColumn1",
				"splitPayment@visa aggregate(groupBy(customer_id),",
				"     price = sum(price)) ~> aggregate",
				"aggregate alterRow(insertIf(1==1)) ~> alterRow1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkDataflow"
			]
		}
	}
}